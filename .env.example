# ===== DATABASE =====
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ===== SERVER =====
PORT=3000
NODE_ENV=production
PUBLIC_URL=https://your-domain.com

# ===== JWT & SECURITY =====
JWT_SECRET=your-very-secure-random-secret-key-min-32-chars

# ===== EMAIL SERVICE (Resend) =====
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxx
EMAIL_FROM=Babaclick <your-email@resendmail.com>
ADMIN_EMAIL=owner@yourcompany.com

# ===== OWNER EMAIL (for approvals) =====
OWNER_EMAIL=owner@yourcompany.com

# ===== OPTIONAL: Google Sheets Integration =====
SPREADSHEET_ID=your_google_sheet_id
GOOGLE_SHEETS_API_KEY=your_api_key

# ===== OPTIONAL: ShipStation Integration =====
SHIPSTATION_API_KEY=your_shipstation_key
